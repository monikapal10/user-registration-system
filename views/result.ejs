<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Success</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
.card {
    padding: 25px;
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    max-width: 400px;
    margin: 50px auto;
    text-align: center;
    background: #fff;
}
</style>
</head>
<body>
<div class="card">
    <h2 class="text-success">Registration Successful 🎉</h2>
    <p><b>Name:</b> <%= name %></p>
    <p><b>Email:</b> <%= email %></p>
    <a href="/" class="btn btn-primary mt-3">Go Back</a>
</div>
</body>
</html>
